<%- include('../layout/header') %>
<%- include('../layout/sidebar') %>

<div class="form-container">
  <div class="console-box form-card">
    <div class="card-glow"></div>
    <div class="console-header">
      <h3 class="console-title">
        <i class="fa-solid <%= isEdit ? 'fa-pen-to-square' : 'fa-plus' %>"></i>
        <%= isEdit ? `Modify Telemetry Record #${log.id}` : 'Record Telemetry Signal Log' %>
      </h3>
      <a href="/telemetry" class="btn-secondary btn-sm">
        <i class="fa-solid fa-arrow-left"></i> Cancel
      </a>
    </div>

    <div class="console-body">
      <% if (error) { %>
        <div class="alert alert-danger" id="formAlert">
          <i class="fa-solid fa-circle-exclamation"></i>
          <span><%= error %></span>
          <button class="alert-close" onclick="document.getElementById('formAlert').remove()">&times;</button>
        </div>
      <% } %>

      <form action="<%= isEdit ? `/telemetry/edit/${log.id}` : '/telemetry/create' %>" method="POST" id="telemetryForm" class="system-form">
        
        <div class="form-group">
          <label for="satellite_id"><i class="fa-solid fa-satellite"></i> Target Satellite Spacecraft</label>
          <select id="satellite_id" name="satellite_id" required>
            <option value="" disabled <%= !log.satellite_id ? 'selected' : '' %>>Select Target Satellite...</option>
            <% satellites.forEach(sat => { %>
              <option value="<%= sat.id %>" <%= log.satellite_id == sat.id ? 'selected' : '' %>><%= sat.satellite_name %></option>
            <% }) %>
          </select>
          <small class="form-help">Choose the satellite source for this signal log.</small>
        </div>

        <div class="form-group">
          <label for="signal_strength"><i class="fa-solid fa-gauge"></i> Link Signal Strength (dBm)</label>
          <input type="number" step="0.01" min="-150.00" max="0.00" id="signal_strength" name="signal_strength" value="<%= log.signal_strength || '' %>" placeholder="e.g. -72.45 (between -150 and 0)" required>
          <small class="form-help">Enter signal strength decibels-milliwatts (dBm). Standard values range from -140 dBm (weak) to -40 dBm (strong).</small>
        </div>

        <div class="form-group">
          <label for="timestamp"><i class="fa-solid fa-clock"></i> Acquisition Timestamp</label>
          <input type="datetime-local" id="timestamp" name="timestamp" value="<%= log.timestamp || '' %>" required>
          <small class="form-help">Specify when the transmission packets were captured.</small>
        </div>

        <div class="form-group">
          <label for="notes"><i class="fa-solid fa-comment-dots"></i> Operator Notes & Diagnostics</label>
          <textarea id="notes" name="notes" placeholder="e.g. Packet loss 0.2%, connection stabilized..." rows="4" maxlength="500"><%= log.notes || '' %></textarea>
          <small class="form-help">Optional: Describe tracking status, orbit adjustments, solar panel angles, or link quality observations.</small>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn-primary">
            <i class="fa-solid fa-floppy-disk"></i> <%= isEdit ? 'Commit Log Entry' : 'Inject Signal Log' %>
          </button>
          <a href="/telemetry" class="btn-secondary">Back to Logs</a>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../layout/footer') %>
